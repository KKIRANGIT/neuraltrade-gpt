# NeuralTrade Environment Variables
# Copy this file to .env and fill in all values

# Broker APIs
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_ACCESS_TOKEN=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Database
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_DB=neuraltrade
TIMESCALEDB_USER=neuraltrade
TIMESCALEDB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092

# External APIs
FINNHUB_API_KEY=
TELEGRAM_BOT_TOKEN=

# Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# JWT
JWT_SECRET=
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# ML Models
MODEL_DIR=/app/models
MIN_ACCURACY_TO_DEPLOY=0.62

# Trading Config
ACCOUNT_CAPITAL=500000
DEFAULT_RISK_PERCENT=1.5
MAX_OPEN_TRADES=4
MIN_CONFLUENCE_SCORE=75
MIN_RR_RATIO=2.0

# Market Hours (IST)
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
SIGNAL_CUTOFF_TIME=14:00
